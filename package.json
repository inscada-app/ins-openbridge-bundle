    "url": "git+https://github.com/inscada-app/ins-openbridge-bundle.git"
  },
  "bugs": {
    "url": "https://github.com/inscada-app/ins-openbridge-bundle/issues"
  },
  "homepage": "https://github.com/inscada-app/ins-openbridge-bundle#readme",
  "dependencies": {
    "@oicl/openbridge-webcomponents": "^1.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.0",
    "vite": "^7.0.0"
  }
